# CLORAG Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys
# =============================================================================

# Anthropic API Key (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voyage AI API Key (required for embeddings)
# Get from: https://dash.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key_here

# =============================================================================
# Qdrant Configuration
# =============================================================================

# Qdrant server URL (your VPS Hostinger)
QDRANT_URL=http://your_vps_ip:6333

# Qdrant API Key (if authentication enabled)
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection names
QDRANT_DOCS_COLLECTION=docusaurus_docs
QDRANT_CASES_COLLECTION=gmail_cases

# =============================================================================
# Voyage AI Embeddings
# =============================================================================

# Embedding model
VOYAGE_MODEL=voyage-context-3

# Vector dimensions (1024 is default for voyage-context-3)
VOYAGE_DIMENSIONS=1024

# =============================================================================
# Docusaurus Documentation
# =============================================================================

# Base URL of your Docusaurus documentation
DOCUSAURUS_URL=https://your-docs-site.com

# =============================================================================
# Jina Reader (Content Extraction)
# =============================================================================

# Use Jina Reader API for web content extraction (r.jina.ai)
# Produces cleaner markdown optimized for LLM/embeddings
USE_JINA_READER=true

# Jina AI API key (optional, for higher rate limits)
# Get from: https://jina.ai/reader/
# JINA_API_KEY=jina_xxxxxxxxxxxx

# =============================================================================
# Gmail Configuration
# =============================================================================

# Gmail label to filter for support threads
GMAIL_LABEL=supports

# Path to OAuth credentials file (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Path to store OAuth token
GOOGLE_TOKEN_PATH=token.json

# =============================================================================
# Agent Configuration
# =============================================================================

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum turns per conversation
MAX_TURNS=50

# =============================================================================
# Camera Database
# =============================================================================

# SQLite database path for camera compatibility data
DATABASE_PATH=data/clorag.db

# Admin password for camera management interface
# Required for /admin/cameras routes
# Also used for encrypting OAuth tokens at rest
ADMIN_PASSWORD=your_secure_admin_password_here

# =============================================================================
# Security Settings
# =============================================================================

# Use secure (HTTPS-only) cookies. Set to False for local development.
SECURE_COOKIES=true

# =============================================================================
# Chunking Configuration
# =============================================================================

# Use token-based chunking instead of character-based (recommended)
# Token-based provides 15-20% more consistent chunk sizes
CHUNK_USE_TOKENS=true

# Chunk size for documentation (in tokens when CHUNK_USE_TOKENS=true)
# Recommended: 400-512 tokens for documentation
CHUNK_SIZE_DOCS=450

# Chunk size for support cases (in tokens when CHUNK_USE_TOKENS=true)
# Recommended: 256-400 tokens for support cases (shorter = more precise)
CHUNK_SIZE_CASES=350

# Default chunk size for other content types
CHUNK_SIZE_DEFAULT=400

# Chunk overlap (~12.5% of default size)
CHUNK_OVERLAP=50

# Content below this token count stays as single chunk
CHUNK_ADAPTIVE_THRESHOLD=200
